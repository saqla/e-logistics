// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Audit logs
  auditLogs AuditLog[]
  staffs    Staff[]

  @@map("users")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String   // "login", "logout", etc.
  details   String?  // Additional details in JSON format
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

// スタッフの種別
enum StaffKind {
  ALL     // All（どの業務にも割当可能）
  UNIC    // ユニック
  HAKO    // 箱車
  JIMU    // 事務
}

// スタッフ
model Staff {
  id         String     @id @default(cuid())
  name       String
  kind       StaffKind
  userId     String?    @unique
  user       User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  deletedAt  DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  // relations
  routeAssignments RouteAssignment[]
  lowerAssignments LowerAssignment[]
  driverShiftAssignments ShiftAssignment[]
  shiftRestDays ShiftRestDay[]

  @@index([name])
  @@map("staffs")
}

// 上段：通常業務以外のメモ（1セル=テキストのみ）
model DayNote {
  id        String   @id @default(cuid())
  year      Int
  month     Int      // 1-12
  day       Int      // 1-31（表示都合で31固定想定）
  slot      Int      // 1..4（上段メモのスロット）
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([year, month, day, slot], name: "year_month_day_slot")
  @@map("day_notes")
}

// 上段最下部3行のルート種別
enum RouteKind {
  ESAKI_DONKI
  SANCHOKU
  MARUNO_DONKI
}

// 連結/休配の特別値（前日継続・配送なし）
enum RouteSpecialValue {
  CONTINUE  // ―
  OFF       // ×
}

// 下段セルの色
enum LowerCellColor {
  WHITE
  PINK
}

// 上段最下部3行：1日×3行の担当
model RouteAssignment {
  id        String    @id @default(cuid())
  year      Int
  month     Int
  day       Int
  route     RouteKind
  staffId   String?
  special   RouteSpecialValue?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  staff     Staff?    @relation(fields: [staffId], references: [id])

  @@unique([year, month, day, route])
  @@index([year, month, day])
  @@map("route_assignments")
}

// 下段：休み表示 1日あたり13行
model LowerAssignment {
  id        String   @id @default(cuid())
  year      Int
  month     Int
  day       Int
  rowIndex  Int      // 1..13
  staffId   String?
  color     LowerCellColor @default(WHITE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff     Staff?   @relation(fields: [staffId], references: [id])

  // 同じ日に同じスタッフを重複選択させない（NULLは許容）
  @@unique([year, month, day, staffId])
  @@unique([year, month, day, rowIndex])
  @@index([year, month, day])
  @@map("lower_assignments")
}

// 右側備考エリア
model Remark {
  id        String   @id @default(cuid())
  title     String
  body      String
  category  String?  // 'common' | 'sanchoku' | 'esaki' | 'maruno'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("remarks")
}

// 箱車シフト用の連絡（備考とは独立）
model ShiftContact {
  id        String   @id @default(cuid())
  title     String?
  body      String
  category  String?  // 'common' | 'sanchoku' | 'esaki' | 'maruno'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("shift_contacts")
}

// ルート一覧（管理画面用）
model RouteDefinition {
  id         String   @id @default(cuid())
  key        String   @unique   // 'ESAKI_DONKI' | 'SANCHOKU' | 'MARUNO_DONKI' | etc
  name       String             // 表示名
  order      Int      @default(0)
  bgClass    String   @default("") // Tailwind背景色クラス
  textClass  String   @default("") // Tailwind文字色クラス
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("route_definitions")
}

// 箱車の車両マスタ（管理画面から追加・編集する固定の車番一覧）
model Vehicle {
  id        String   @id @default(cuid())
  number    String   @unique // 表示名兼キー: '0514' | 'ユニック' など
  order     Int      @default(0)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments ShiftAssignment[]

  @@map("vehicles")
}

// 箱車シフト画面の「休み」固定行：1日に複数人を割当可能なので車両とは独立管理
model ShiftRestDay {
  id        String   @id @default(cuid())
  year      Int
  month     Int
  day       Int
  staffId   String
  kind      String   @default("PUBLIC") // 'PUBLIC'(公休) | 'PAID'(有給)
  createdAt DateTime @default(now())

  staff     Staff    @relation(fields: [staffId], references: [id])

  @@unique([year, month, day, staffId])
  @@index([year, month, day])
  @@map("shift_rest_days")
}

// 箱車シフト：1日×車両ごとの割当（ルート＋担当ドライバー）
model ShiftAssignment {
  id        String          @id @default(cuid())
  year      Int
  month     Int
  day       Int
  vehicleId String
  route     String?         // RouteDefinition.key を直接保持（未割当/空車時はnull）
  driverStaffId String?     // 未割当（空車）時はnull
  noteBL    String?         // 左下セル（自由入力）
  noteBR    String?         // 右下セル（自由入力）
  scheduleRouteKey RouteKind? // 予定表の3ルート種別への明示上書き
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  vehicle   Vehicle         @relation(fields: [vehicleId], references: [id])
  driver    Staff?          @relation(fields: [driverStaffId], references: [id])

  @@unique([year, month, day, vehicleId])
  @@index([year, month, day])
  @@map("shift_assignments")
}